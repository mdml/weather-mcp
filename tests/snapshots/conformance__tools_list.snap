---
source: tests/conformance.rs
expression: shapes
---
[
  {
    "description": "Compare a period of interest against a climate baseline using calendar-window matching: returns the period aggregate, the per-year baseline distribution, and anomaly scores (absolute, percent, z-score, percentile, rank).",
    "input_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "`compare_period` request (§4.3).\n\nThe period of interest is two flat top-level `YYYY-MM-DD` params (not a nested object): a\nnested struct surfaces in the published schema as a reference into a shared definitions block,\nwhich many MCP clients / LLM tool-callers don't follow (they then send `period` as a bare\nstring and serde rejects it). Flat string params match `get_historical`'s reliable\n`start_date`/`end_date`.",
      "properties": {
        "baseline_end_year": {
          "default": 2020,
          "description": "≥ 1940 (§4.1).",
          "format": "int32",
          "type": "integer"
        },
        "baseline_start_year": {
          "default": 1991,
          "description": "≥ 1940 (§4.1).",
          "format": "int32",
          "type": "integer"
        },
        "include_series": {
          "default": false,
          "description": "Adds the day-by-day series for the time-series view (§4.5).",
          "type": "boolean"
        },
        "latitude": {
          "default": null,
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "location": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "longitude": {
          "default": null,
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "period_end": {
          "description": "`YYYY-MM-DD`, the end of the window of interest, clamped per the ERA5 lag (§1.7).",
          "type": "string"
        },
        "period_start": {
          "description": "`YYYY-MM-DD`, the start of the window of interest.",
          "type": "string"
        },
        "units": {
          "default": "metric",
          "description": "The single `units` knob (§1.2). Maps to Open-Meteo's three unit params and to the labels\nechoed in every output envelope.\n\n`#[schemars(inline)]` forces this enum's schema to be emitted at every use site rather than\nbehind a JSON-Schema reference into a shared definitions block. Many MCP clients / LLM\ntool-callers don't follow those references, so the `metric`/`imperial` choices must appear\ninline at the param — otherwise callers have to hand-quote the value blind.",
          "oneOf": [
            {
              "const": "metric",
              "description": "°C · mm · km/h.",
              "type": "string"
            },
            {
              "const": "imperial",
              "description": "°F · inch · mph.",
              "type": "string"
            }
          ]
        },
        "variables": {
          "default": [
            "temperature",
            "precipitation"
          ],
          "items": {
            "description": "The fixed, snapshot-testable variable enum for the historical/comparison path (§1.4).\n`get_forecast` is intentionally *not* limited to this set.\n\n`#[schemars(inline)]` for the same reason as [`Units`]: emit the enum at every use site\nrather than behind a shared schema reference, so reference-blind MCP clients still see the\nallowed values.",
            "enum": [
              "temperature",
              "precipitation",
              "snowfall",
              "wind"
            ],
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "period_start",
        "period_end"
      ],
      "title": "CompareRequest",
      "type": "object"
    },
    "name": "compare_period"
  },
  {
    "description": "Current conditions and an N-day daily forecast for a location (by name or coordinates). Returns current weather plus a chart-friendly daily series.",
    "input_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "`get_forecast` request (§2). Exactly one of `location` vs `latitude`+`longitude` (§1.1).",
      "properties": {
        "forecast_days": {
          "default": 7,
          "description": "1–16; Open-Meteo max is 16.",
          "format": "uint8",
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        },
        "latitude": {
          "default": null,
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "location": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "longitude": {
          "default": null,
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "units": {
          "default": "metric",
          "description": "The single `units` knob (§1.2). Maps to Open-Meteo's three unit params and to the labels\nechoed in every output envelope.\n\n`#[schemars(inline)]` forces this enum's schema to be emitted at every use site rather than\nbehind a JSON-Schema reference into a shared definitions block. Many MCP clients / LLM\ntool-callers don't follow those references, so the `metric`/`imperial` choices must appear\ninline at the param — otherwise callers have to hand-quote the value blind.",
          "oneOf": [
            {
              "const": "metric",
              "description": "°C · mm · km/h.",
              "type": "string"
            },
            {
              "const": "imperial",
              "description": "°F · inch · mph.",
              "type": "string"
            }
          ]
        }
      },
      "title": "ForecastRequest",
      "type": "object"
    },
    "name": "get_forecast"
  },
  {
    "description": "The daily historical weather record (ERA5) for an explicit date window: temperature, precipitation, snowfall, and/or wind for the requested variables.",
    "input_schema": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "description": "`get_historical` request (§3).",
      "properties": {
        "end_date": {
          "description": "`YYYY-MM-DD`, clamped per the ERA5 lag (§1.7).",
          "type": "string"
        },
        "latitude": {
          "default": null,
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "location": {
          "default": null,
          "type": [
            "string",
            "null"
          ]
        },
        "longitude": {
          "default": null,
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "start_date": {
          "description": "`YYYY-MM-DD`, ≥ 1940-01-01.",
          "type": "string"
        },
        "units": {
          "default": "metric",
          "description": "The single `units` knob (§1.2). Maps to Open-Meteo's three unit params and to the labels\nechoed in every output envelope.\n\n`#[schemars(inline)]` forces this enum's schema to be emitted at every use site rather than\nbehind a JSON-Schema reference into a shared definitions block. Many MCP clients / LLM\ntool-callers don't follow those references, so the `metric`/`imperial` choices must appear\ninline at the param — otherwise callers have to hand-quote the value blind.",
          "oneOf": [
            {
              "const": "metric",
              "description": "°C · mm · km/h.",
              "type": "string"
            },
            {
              "const": "imperial",
              "description": "°F · inch · mph.",
              "type": "string"
            }
          ]
        },
        "variables": {
          "default": [
            "temperature",
            "precipitation"
          ],
          "items": {
            "description": "The fixed, snapshot-testable variable enum for the historical/comparison path (§1.4).\n`get_forecast` is intentionally *not* limited to this set.\n\n`#[schemars(inline)]` for the same reason as [`Units`]: emit the enum at every use site\nrather than behind a shared schema reference, so reference-blind MCP clients still see the\nallowed values.",
            "enum": [
              "temperature",
              "precipitation",
              "snowfall",
              "wind"
            ],
            "type": "string"
          },
          "type": "array"
        }
      },
      "required": [
        "start_date",
        "end_date"
      ],
      "title": "HistoricalRequest",
      "type": "object"
    },
    "name": "get_historical"
  }
]
