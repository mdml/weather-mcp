# weather-mcp — Codex command rules (committed, hand-maintained).
#
# Starlark prefix grammar mirroring the Claude allow/ask/deny matrix in
# .claude/settings.json. Codex has no `ask` bucket — Claude `ask` items become
# `forbid` here for safety. Keep this in sync with .claude/settings.json by hand.

# === Allow ==================================================================
allow("pwd")
allow("ls")
allow("ls", ARGS)
allow("mkdir", ARGS)
allow("rmdir", ARGS)
allow("rm")
allow("rm", ARGS)
allow("mv", ARGS)
allow("cp", ARGS)
allow("which", ARGS)
allow("wc", ARGS)
allow("dirname", ARGS)
allow("basename", ARGS)
allow("realpath", ARGS)
allow("stat", ARGS)
allow("file", ARGS)
allow("touch", ARGS)
allow("diff", ARGS)
allow("sort", ARGS)
allow("uniq", ARGS)
allow("tr", ARGS)
allow("cut", ARGS)
allow("jq", ARGS)
allow("date")
allow("date", ARGS)
allow("just")
allow("just", ARGS)
allow("cargo", ARGS)
allow("rustc", ARGS)
allow("rustup", ARGS)
allow("rustfmt", ARGS)
allow("gh", ARGS)
allow("git", "status", ARGS)
allow("git", "diff", ARGS)
allow("git", "log", ARGS)
allow("git", "show", ARGS)
allow("git", "branch", ARGS)
allow("git", "stash", ARGS)
allow("git", "fetch", ARGS)
allow("git", "pull", ARGS)
allow("git", "ls-files", ARGS)
allow("git", "rev-parse", ARGS)
allow("git", "blame", ARGS)
allow("git", "remote", ARGS)
allow("git", "tag", ARGS)
allow("git", "add", ARGS)
allow("git", "rm", ARGS)
allow("git", "mv", ARGS)
allow("git", "commit", ARGS)
allow("git", "push", ARGS)
allow("git", "checkout", ARGS)
allow("git", "switch", ARGS)
allow("git", "merge", ARGS)
allow("git", "rebase", ARGS)
allow("git", "worktree", ARGS)

# === Forbid (Claude `deny` + `ask`, since Codex has no `ask`) ===============
forbid("git", "push", "--force-with-lease", ARGS)
forbid("curl", ARGS)
forbid("wget", ARGS)
forbid("rm", "-rf", ARGS)
forbid("rm", "-r", ARGS)
forbid("rm", "--recursive", ARGS)
forbid("git", "push", "--force")
forbid("git", "push", "--force", ARGS)
forbid("git", "push", "-f")
forbid("git", "push", "-f", ARGS)
forbid("git", "reset", "--hard", ARGS)
forbid("git", "clean", "-f", ARGS)
forbid("git", "clean", "-fd", ARGS)
forbid("git", "commit", "--no-verify", ARGS)
forbid("git", "commit", "-n", ARGS)
forbid("git", "push", "--no-verify", ARGS)
forbid("git", "rebase", "--no-verify", ARGS)
forbid("cd", ARGS)
forbid("pushd", ARGS)
forbid("popd", ARGS)
forbid("git", "-C", ARGS)
